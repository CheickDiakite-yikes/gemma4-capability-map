# Copy this file to .env.local and fill in values you actually want to use.
HF_TOKEN=

# Optional: point the runtime at local model directories instead of remote repo ids.
# GEMMA4_E2B_PATH=/absolute/path/to/gemma-4-E2B-it
# GEMMA4_E4B_PATH=/absolute/path/to/gemma-4-E4B-it
# FUNCTIONGEMMA_PATH=/absolute/path/to/functiongemma-270m
# EMBEDDINGGEMMA_PATH=/absolute/path/to/embeddinggemma

# Optional: force local-cache-only / offline behavior once weights are present.
# GEMMA4_OFFLINE=1
