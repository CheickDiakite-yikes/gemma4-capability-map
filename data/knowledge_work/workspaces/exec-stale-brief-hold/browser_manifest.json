        {
          "transition_id": "exec_stale_brief_validation_recovered",
          "action": "repair_seeded_draft",
          "from_state": "brief_validation_failed",
          "to_state": "brief_ready",
          "outcome": "recovered",
          "notes": "Repair the board brief to the latest approved version without widening the recipient list"
        },
        {
          "transition_id": "exec_stale_brief_workspace_reopened",
          "action": "open_seeded_workspace",
          "from_state": "brief_ready",
          "to_state": "workspace_reopened",
          "outcome": "pass",
          "notes": "Reopen the board-brief workspace for the send decision"
        },
        {
          "transition_id": "exec_stale_brief_send_blocked",
          "action": "attempt_seeded_send",
          "from_state": "workspace_reopened",
          "to_state": "send_blocked_pending_approval",
          "outcome": "approval_required",
          "notes": "Attempt the send path and record that the latest brief still cannot be sent before executive approval"
        }
